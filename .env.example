# ── App ────────────────────────────────────────────────────────────────────────
NODE_ENV=development
HOST=0.0.0.0
PORT=5000
APP_URL=http://your-server-ip:3000

# ── JWT ─────────────────────────────────────────────────────────────────────────
JWT_SECRET=your_long_random_jwt_secret_change_this_in_production
JWT_EXPIRY=8h

# ── Admin seed account (auto-created on first run if no users exist) ─────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme
ADMIN_NAME=Admin

# ── MongoDB ──────────────────────────────────────────────────────────────────────
MONGO_INITDB_ROOT_USERNAME=your_db_username
MONGO_INITDB_ROOT_PASSWORD=changeme
MONGO_INITDB_DATABASE=your_database_name
MONGO_URI=mongodb://your_db_username:changeme@mongo:27017/your_database_name?authSource=admin

# For local development (outside Docker):
# MONGO_URI=mongodb://your_db_username:changeme@localhost:27017/your_database_name?authSource=admin

# ── QBO OAuth (Intuit Developer Portal) ─────────────────────────────────────────
QBO_CLIENT_ID=your_intuit_client_id
QBO_CLIENT_SECRET=your_intuit_client_secret
QBO_REDIRECT_URI=http://localhost:5000/api/auth/qbo/callback
QBO_ENVIRONMENT=sandbox
QBO_MINOR_VERSION=65

# ── Default settings ─────────────────────────────────────────────────────────────
DEFAULT_SUPERVISOR=Your Supervising Clinician Name, Credentials
